# Copy this file to .env.local and fill in your keys

# Required: OpenAI API Key (for GPT-4.1/GPT-4o)
OPENAI_API_KEY=sk-...

# Optional: Use Claude instead of OpenAI
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Alpha Vantage for real stock data
# ALPHA_VANTAGE_API_KEY=...

# Optional: NewsAPI for real news
# NEWS_API_KEY=...

# Required for rate-limiting (optional but recommended)
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
